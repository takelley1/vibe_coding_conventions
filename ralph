def overlap(start, end):
    total = 0
    for item in segments:
        if not isinstance(item, list) or len(item) != 2:
            continue
        s, e = item
        try:
            s = int(s); e = int(e)
        except Exception:
            continue
        if e <= start or s >= end:
            continue
        total += max(0, min(e, end) - max(s, start))
    return total

