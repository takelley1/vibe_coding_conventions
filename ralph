#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RALPH_DIR="${SCRIPT_DIR}/ralph_tool"
VENV_DIR="${RALPH_DIR}/.venv"
PYTHON_BIN="${VENV_DIR}/bin/python"
ACTIVATE_SCRIPT="${VENV_DIR}/bin/activate"
DEPS_STAMP="${VENV_DIR}/.deps-installed"
NEEDS_INSTALL=0

if [[ ! -x "${PYTHON_BIN}" ]]; then
  if ! command -v python3.12 >/dev/null 2>&1; then
    echo "ERROR: python3.12 is required to bootstrap ${VENV_DIR}" >&2
    exit 1
  fi

  echo "Bootstrapping Python virtualenv at ${VENV_DIR}..."
  python3.12 -m venv "${VENV_DIR}"
  NEEDS_INSTALL=1
fi

# shellcheck disable=SC1091
source "${ACTIVATE_SCRIPT}"

PY_VERSION="$(python -c 'import sys; print(f"{sys.version_info.major}.{sys.version_info.minor}")')"
if [[ "${PY_VERSION}" != "3.12" ]]; then
  echo "ERROR: Ralph requires Python 3.12 in .venv, found ${PY_VERSION}" >&2
  exit 1
fi

if [[ ! -f "${DEPS_STAMP}" ]]; then
  NEEDS_INSTALL=1
fi
if ! python -c "import rich" >/dev/null 2>&1; then
  NEEDS_INSTALL=1
fi

if [[ "${NEEDS_INSTALL}" -eq 1 ]]; then
  echo "Installing Ralph dependencies into ${VENV_DIR}..."
  python -m pip install -r "${RALPH_DIR}/requirements-dev.txt"
  touch "${DEPS_STAMP}"
fi

exec python "${RALPH_DIR}/ralph.py" "$@"
